{
  "name": "@geometra/renderer-three",
  "version": "0.1.0",
  "description": "Three.js render target helpers for Geometra — stack WebGL with the geometry-streamed canvas client",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra-renderer-three"
  },
  "keywords": [
    "geometra",
    "three",
    "three.js",
    "webgl",
    "renderer",
    "dom-free",
    "websocket"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@geometra/renderer-canvas": "^1.2.1",
    "three": ">=0.160.0 <0.180.0"
  },
  "devDependencies": {
    "@geometra/renderer-canvas": "^1.2.1",
    "@types/three": "^0.170.0",
    "three": "^0.170.0",
    "typescript": "^6.0.2"
  }
}
