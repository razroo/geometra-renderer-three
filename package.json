{
  "name": "@geometra/renderer-three",
  "version": "0.2.0",
  "description": "Three.js render target helpers for Geometra — stack WebGL with the geometry-streamed canvas client",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra-renderer-three"
  },
  "keywords": [
    "geometra",
    "three",
    "three.js",
    "webgl",
    "renderer",
    "dom-free",
    "websocket"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "verify:exports": "node scripts/verify-exports.mjs",
    "verify:utils": "node scripts/verify-utils.mjs",
    "verify:layout-sync": "node scripts/verify-layout-sync.mjs",
    "verify:host-css-coerce": "node scripts/verify-host-css-coerce.mjs",
    "release:gate": "npm run check && npm run build && npm run verify:exports && npm run verify:utils && npm run verify:layout-sync && npm run verify:host-css-coerce",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@geometra/renderer-canvas": "^1.2.2",
    "three": ">=0.160.0 <0.180.0"
  },
  "devDependencies": {
    "@geometra/client": "^1.2.2",
    "@geometra/renderer-canvas": "^1.2.2",
    "@types/three": "^0.170.0",
    "three": "^0.170.0",
    "typescript": "^6.0.2"
  }
}
